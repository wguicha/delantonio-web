# Database
DATABASE_URL="postgresql://user:password@localhost:5432/delantonio_db"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=development

# CORS
FRONTEND_URL=http://localhost:5173

# WhatsApp Business API (Meta)
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
ADMIN_PHONE=34600000000

# Geolocation - pizzeria coordinates and max distance (km)
PIZZERIA_LAT=36.7213
PIZZERIA_LNG=-4.4213
MAX_ORDER_RADIUS_KM=50

# Rate limiting
ORDER_RATE_LIMIT_WINDOW_MS=3600000
ORDER_RATE_LIMIT_MAX=5

# Admin credentials (used by seed on first run - CHANGE IN PRODUCTION)
ADMIN_PASSWORD=admin123
